# Native observability defaults (Scarthgap baseline).
# Telegraf reads non-secret defaults via EnvironmentFile in telegraf.service.
# Secrets are provided via systemd credentials from:
#   /etc/credstore/telegraf.service.mqtt_username
#   /etc/credstore/telegraf.service.mqtt_password
#   /etc/credstore/telegraf.service.influxdb_username
#   /etc/credstore/telegraf.service.influxdb_password
# Override non-secret values via kas/local.yml or a target drop-in at:
#   /etc/default/iotgw-observability

# InfluxDB 1.x endpoint and database used by outputs.influxdb.
INFLUXDB_URL=http://127.0.0.1:8086
INFLUXDB_DATABASE=gateway_data
