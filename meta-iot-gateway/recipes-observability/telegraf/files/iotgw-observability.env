# Non-secret observability defaults consumed by telegraf.service via
# EnvironmentFile=-/etc/default/iotgw-observability.
#
# Secrets are NOT placed here -- credentials are delivered to telegraf via
# systemd LoadCredential= from /etc/credstore/telegraf.service.* (mode 0600,
# root:root) and surfaced inside the unit at $CREDENTIALS_DIRECTORY. The
# secretstores.systemd Telegraf plugin reads them from that per-unit tmpfs;
# they never appear in the environment, in argv, in /proc/$PID/environ, or
# in core dumps.
#
# Defaults left empty so a fresh image surfaces a clean
# condition-failed/config-error rather than silently writing to a wrong
# endpoint. Integrators populate via build-time override
# (kas/local.yml local_conf_header) or runtime overlay edit.

INFLUXDB_URL=
INFLUXDB_DATABASE=
