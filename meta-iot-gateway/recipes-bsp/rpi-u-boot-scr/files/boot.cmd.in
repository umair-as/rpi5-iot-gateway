# IoT Gateway customized bootscript for Raspberry Pi (U-Boot)
# Based on meta-raspberrypi default; adds banner and optional splash

setenv iotgw_banner "IoT Gateway — U-Boot Boot"
echo ""
echo "===================================================="
echo "  ${iotgw_banner}"
echo "----------------------------------------------------"
echo "  Platform : Raspberry Pi 5"
echo "  Boot     : U-Boot (script)"
echo "===================================================="
echo "Boot media: @@BOOT_MEDIA@@  | Image: @@KERNEL_IMAGETYPE@@"
if test -n "${iotgw_build}"; then
    echo "Build     : ${iotgw_build}"
fi
if test -n "${iotgw_last_update}"; then
    echo "Updated   : ${iotgw_last_update}"
fi
if test -n "${iotgw_bootcount}"; then
    echo "Boot cnt  : ${iotgw_bootcount}"
fi

# Display splash if present in /boot (no env toggle required)
if fatload @@BOOT_MEDIA@@ 0:1 ${loadaddr} splash.bmp; then
    echo "Displaying splash..."
    # Clear any earlier framebuffer contents (e.g., built-in U-Boot logo)
    cls
    bmp display ${loadaddr} m m
fi

# Determine slot to boot (RAUC integration)
# Upstream RAUC pattern: respect BOOT_ORDER and per-slot remaining tries.
# Defaults for first boot if env not initialized
test -n "${BOOT_ORDER}" || setenv BOOT_ORDER "A B"
test -n "${BOOT_A_LEFT}" || setenv BOOT_A_LEFT 3
test -n "${BOOT_B_LEFT}" || setenv BOOT_B_LEFT 3

echo "[RAUC] Bootchooser init (env):"
env print BOOT_ORDER BOOT_A_LEFT BOOT_B_LEFT

setenv bootpart
setenv rootpartnum
setenv rauc_slot

for BOOT_SLOT in ${BOOT_ORDER}; do
    if test "x${bootpart}" != "x"; then
        # already selected a slot; skip others
    elif test "x${BOOT_SLOT}" = "xA"; then
        if itest ${BOOT_A_LEFT} -gt 0; then
            echo "[RAUC] Considering slot A; tries left before dec=${BOOT_A_LEFT}"
            setexpr BOOT_A_LEFT ${BOOT_A_LEFT} - 1
            echo "[RAUC] Selected slot A; tries left now=${BOOT_A_LEFT}"
            setenv bootpart "/dev/mmcblk0p3"
            setenv rootpartnum "3"
            setenv rauc_slot "A"
        else
            echo "[RAUC] Skipping slot A; no tries left"
        fi
    elif test "x${BOOT_SLOT}" = "xB"; then
        if itest ${BOOT_B_LEFT} -gt 0; then
            echo "[RAUC] Considering slot B; tries left before dec=${BOOT_B_LEFT}"
            setexpr BOOT_B_LEFT ${BOOT_B_LEFT} - 1
            echo "[RAUC] Selected slot B; tries left now=${BOOT_B_LEFT}"
            setenv bootpart "/dev/mmcblk0p4"
            setenv rootpartnum "4"
            setenv rauc_slot "B"
        else
            echo "[RAUC] Skipping slot B; no tries left"
        fi
    fi
done

# Build kernel cmdline: start from firmware-provided args, then append root per slot
fdt addr ${fdt_addr} && fdt get value bootargs /chosen bootargs
if test -n "${bootpart}"; then
    if test -z "${rootpartnum}"; then
        echo "[RAUC] Missing root partition number for slot ${rauc_slot}; resetting"
        reset
    fi
    if part uuid @@BOOT_MEDIA@@ 0:${rootpartnum} rootpartuuid; then
        setenv rootarg "root=PARTUUID=${rootpartuuid}"
        echo "[RAUC] Using root from PARTUUID=${rootpartuuid} (slot ${rauc_slot})"
    else
        echo "[RAUC] PARTUUID lookup failed for slot ${rauc_slot}; resetting"
        reset
    fi
    setenv bootargs "${bootargs} ${rootarg} rauc.slot=${rauc_slot}"
    # Track boot count and last selected slot
    if test -z "${iotgw_bootcount}"; then
        setenv iotgw_bootcount 0
    fi
    setexpr iotgw_bootcount ${iotgw_bootcount} + 1
    setenv iotgw_last_slot ${rauc_slot}
    # Optional extra kernel args from environment for runtime tuning (e.g., cma=256M)
    if test -n "${EXTRA_KERNEL_ARGS}"; then
        echo "[RAUC] Appending EXTRA_KERNEL_ARGS='${EXTRA_KERNEL_ARGS}'"
        setenv bootargs "${bootargs} ${EXTRA_KERNEL_ARGS}"
    fi
    saveenv
    echo "[RAUC] Bootargs appended; ${rootarg} rauc.slot=${rauc_slot}"
else
    echo "No valid RAUC slot found. Resetting tries to 3"
    setenv BOOT_A_LEFT 3
    setenv BOOT_B_LEFT 3
    saveenv
    reset
fi

echo "[bootscript] Selected RAUC slot ${rauc_slot} (root=${bootpart})"

echo "[RAUC] Loading kernel from boot partition; slot=${rauc_slot} root=${bootpart}"

# Load kernel and boot
if fatload @@BOOT_MEDIA@@ 0:1 ${kernel_addr_r} @@KERNEL_IMAGETYPE@@; then
    echo "[RAUC] Loaded @@KERNEL_IMAGETYPE@@"
else
    echo "[RAUC] Failed to load @@KERNEL_IMAGETYPE@@ from /boot"
    reset
fi
if test ! -e @@BOOT_MEDIA@@ 0:2 uboot.env; then saveenv; fi;

# FIT-mode visibility and explicit configuration selection.
if test "x@@KERNEL_IMAGETYPE@@" = "xfitImage"; then
    test -n "${iotgw_fit_verify}" || setenv iotgw_fit_verify "required"
    test -n "${iotgw_fit_algo}" || setenv iotgw_fit_algo "sha256,rsa2048"
    test -n "${iotgw_fit_conf_default}" || setenv iotgw_fit_conf_default "conf-bcm2712-rpi-5-b.dtb"
    test -n "${iotgw_fit_conf}" || setenv iotgw_fit_conf "${iotgw_fit_conf_default}"
    # Raspberry Pi firmware applies runtime DT fixups/overlays before U-Boot.
    # Use firmware-prepared DTB by default to avoid early-kernel hangs seen
    # with static DTB from FIT config on this platform.
    test -n "${iotgw_fit_external_fdt}" || setenv iotgw_fit_external_fdt "1"

    echo "[FIT] verify=${iotgw_fit_verify} algo=${iotgw_fit_algo}"
    echo "[FIT] config default=${iotgw_fit_conf_default} selected=${iotgw_fit_conf}"

    if test -n "${iotgw_fit_conf}"; then
        if test "x${iotgw_fit_external_fdt}" = "x1"; then
            echo "[FIT] Boot command: @@KERNEL_BOOTCMD@@ ${kernel_addr_r}#${iotgw_fit_conf} - ${fdt_addr}"
            @@KERNEL_BOOTCMD@@ ${kernel_addr_r}#${iotgw_fit_conf} - ${fdt_addr}
        else
            echo "[FIT] Boot command: @@KERNEL_BOOTCMD@@ ${kernel_addr_r}#${iotgw_fit_conf}"
            @@KERNEL_BOOTCMD@@ ${kernel_addr_r}#${iotgw_fit_conf}
        fi
    else
        if test "x${iotgw_fit_external_fdt}" = "x1"; then
            echo "[FIT] Boot command: @@KERNEL_BOOTCMD@@ ${kernel_addr_r} - ${fdt_addr}"
            @@KERNEL_BOOTCMD@@ ${kernel_addr_r} - ${fdt_addr}
        else
            echo "[FIT] Boot command: @@KERNEL_BOOTCMD@@ ${kernel_addr_r}"
            @@KERNEL_BOOTCMD@@ ${kernel_addr_r}
        fi
    fi
else
    # Non-FIT path uses external DTB argument.
    echo "[RAUC] Boot command: @@KERNEL_BOOTCMD@@ ${kernel_addr_r} - ${fdt_addr}"
    @@KERNEL_BOOTCMD@@ ${kernel_addr_r} - ${fdt_addr}
fi
