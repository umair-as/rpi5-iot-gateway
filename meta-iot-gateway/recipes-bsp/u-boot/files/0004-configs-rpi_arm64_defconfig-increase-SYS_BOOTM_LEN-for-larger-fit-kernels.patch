From 121bc536cf81bbf11a5f123847af52126fd6e482 Mon Sep 17 00:00:00 2001
From: Umair Ahmed Shah <umairahmedshah@hotmail.com>
Date: Thu, 7 May 2026 16:24:11 +0200
Subject: [PATCH] configs: rpi_arm64_defconfig: increase SYS_BOOTM_LEN for
 larger FIT kernels

---
 configs/rpi_arm64_defconfig | 1 +
 1 file changed, 1 insertion(+)

diff --git a/configs/rpi_arm64_defconfig b/configs/rpi_arm64_defconfig
index 361ea8d8fd5..ade6860e6da 100644
--- a/configs/rpi_arm64_defconfig
+++ b/configs/rpi_arm64_defconfig
@@ -7,6 +7,7 @@ CONFIG_DEFAULT_DEVICE_TREE="bcm2711-rpi-4-b"
 CONFIG_OF_LIBFDT_OVERLAY=y
 CONFIG_DM_RESET=y
 CONFIG_SYS_LOAD_ADDR=0x1000000
+CONFIG_SYS_BOOTM_LEN=0x8000000
 CONFIG_IDENT_STRING=" (IoT-Gateway)"
 CONFIG_PCI=y
 CONFIG_ENV_VARS_UBOOT_CONFIG=y
