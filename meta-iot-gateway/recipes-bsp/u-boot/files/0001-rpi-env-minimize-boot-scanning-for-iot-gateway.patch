From 86ce83457f08e116752ffa92bc1ecd9aa52025d1 Mon Sep 17 00:00:00 2001
From: Umair Ahmed Shah <umairahmedshah@hotmail.com>
Date: Sat, 30 May 2026 12:00:00 +0000
Subject: [PATCH] rpi: env: minimize boot scanning for IoT Gateway appliance
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Replace the upstream boot_targets="mmc usb pxe dhcp" scan and the
USB-keyboard / USB-tftp env entries with the IoT Gateway RAUC A/B
FIT-boot environment. The gateway boots directly from mmc into one of
two RAUC slots via the iotgw_rauc_select / iotgw_set_bootargs /
iotgw_load_boot / iotgw_exec_fit chain, with iotgw_halt as the
no-slot-bootable terminal state.

The FIT configuration is selected by the FIT's own signed `default`
property (bootm without an explicit #conf). iotgw_fit_conf is an
optional operator override (e.g. a future conf-recovery) and is
intentionally absent from the default environment: keeping the config
name out of the environment removes a boot-critical parameter that
mutable storage or an OTA hook could pin to a stale value. Both slots
load the same FIT, so a stale pinned name fails bootm on every slot
and exhausts all boot counters.

iotgw_load_boot selects the FIT *file* by ${rauc_slot} (fitImage-a /
fitImage-b), matching what the RAUC bundle post-install hook
(bundle-hooks-fit.sh) writes per slot on the shared boot partition —
this pairs each slot's kernel with that slot's rootfs kernel modules,
so an OTA'd kernel is actually loaded on next boot instead of the
stale factory fitImage. A plain fitImage fallback covers the
fresh-flash window before the first OTA has written a per-slot file.
iotgw_rauc_select runs first in bootcmd and always sets rauc_slot
before iotgw_load_boot runs. A load failure of both the per-slot file
and the fallback still burns the slot's attempt counter before
resetting, preserving the existing no-infinite-retry guarantee.

Upstream-Status: Inappropriate [product specific — appliance boot policy]
Signed-off-by: Umair Ahmed Shah <umairahmedshah@hotmail.com>
---
 board/raspberrypi/rpi/rpi.env | 15 ++++++++++++---
 1 file changed, 12 insertions(+), 3 deletions(-)

diff --git a/board/raspberrypi/rpi/rpi.env b/board/raspberrypi/rpi/rpi.env
index 9ac9d6768ca..bef56777b96 100644
--- a/board/raspberrypi/rpi/rpi.env
+++ b/board/raspberrypi/rpi/rpi.env
@@ -2,10 +2,10 @@
 
 /* environment for Raspberry Pi boards */
 
-dhcpuboot=usb start; dhcp u-boot.uimg; bootm
+dhcpuboot=dhcp u-boot.uimg; bootm
 
 /* Environment */
-stdin=serial,usbkbd
+stdin=serial
 stdout=serial,vidconsole
 stderr=serial,vidconsole
 
@@ -77,4 +77,13 @@ pxefile_addr_r=0x05500000
 fdt_addr_r=0x05600000
 ramdisk_addr_r=0x05700000

-boot_targets=mmc usb pxe dhcp
+iotgw_fit_addr_r=0x08000000
+iotgw_try_a=if test -z "${rauc_slot}"; then if itest ${BOOT_A_LEFT} -gt 0; then setexpr BOOT_A_LEFT ${BOOT_A_LEFT} - 1; setenv rauc_slot A; setenv rootpartnum 3; fi; fi
+iotgw_try_b=if test -z "${rauc_slot}"; then if itest ${BOOT_B_LEFT} -gt 0; then setexpr BOOT_B_LEFT ${BOOT_B_LEFT} - 1; setenv rauc_slot B; setenv rootpartnum 4; fi; fi
+iotgw_rauc_select=test -n "${BOOT_ORDER}" || setenv BOOT_ORDER A B; test -n "${BOOT_A_LEFT}" || setenv BOOT_A_LEFT 3; test -n "${BOOT_B_LEFT}" || setenv BOOT_B_LEFT 3; setenv rauc_slot; for BOOT_SLOT in ${BOOT_ORDER}; do if test x${BOOT_SLOT} = xA; then run iotgw_try_a; else run iotgw_try_b; fi; done
+iotgw_set_bootargs=if part uuid mmc 0:${rootpartnum} rootpartuuid; then fdt addr ${fdt_addr}; fdt get value bootargs /chosen bootargs; setenv bootargs ${bootargs} root=PARTUUID=${rootpartuuid} rootwait rauc.slot=${rauc_slot}; if test -n "${EXTRA_KERNEL_ARGS}"; then setenv bootargs ${bootargs} ${EXTRA_KERNEL_ARGS}; fi; else echo [RAUC] part uuid failed; reset; fi
+iotgw_load_boot=if test "x${rauc_slot}" = "xA"; then setenv _fit fitImage-a; elif test "x${rauc_slot}" = "xB"; then setenv _fit fitImage-b; else setenv _fit fitImage; fi; if fatload mmc 0:1 ${iotgw_fit_addr_r} ${_fit}; then echo [IOTGW] FIT ${_fit} loaded; elif fatload mmc 0:1 ${iotgw_fit_addr_r} fitImage; then echo [IOTGW] FIT fallback fitImage loaded; else echo [IOTGW] FIT load failed; setenv BOOT_${rauc_slot}_LEFT 0; saveenv; reset; fi
+iotgw_exec_fit=if test -n "${iotgw_fit_conf}"; then bootm ${iotgw_fit_addr_r}#${iotgw_fit_conf} - ${fdt_addr}; else bootm ${iotgw_fit_addr_r} - ${fdt_addr}; fi; echo [IOTGW] bootm returned for slot ${rauc_slot}: marking slot non-bootable; setenv BOOT_${rauc_slot}_LEFT 0; saveenv; reset
+iotgw_halt=echo [IOTGW][HALT] All RAUC slots exhausted (A_LEFT=${BOOT_A_LEFT} B_LEFT=${BOOT_B_LEFT}); echo [IOTGW][HALT] No bootable FIT image. Out-of-band recovery required (serial console or SD reflash); while itest 1 -eq 1; do sleep 60; echo [IOTGW][HALT] halted; done
+bootcmd=run iotgw_rauc_select; if test -z "${rauc_slot}"; then run iotgw_halt; fi; run iotgw_set_bootargs; run iotgw_load_boot; saveenv; run iotgw_exec_fit
+boot_targets=mmc
-- 
