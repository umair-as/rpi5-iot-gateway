## IoT Gateway Audit Rules (modern syscall-based form)

# Reset any existing rules
-D

# Buffer size and failure mode (1=printk, 2=panic)
-b 8192
-f 1

## Identity files (passwd/group/shadow)
-w /etc/passwd              -p wa -k identity
-w /etc/group               -p wa -k identity
-w /etc/shadow              -p wa -k identity
-w /etc/gshadow             -p wa -k identity
-w /etc/security/opasswd    -p wa -k identity

## Login configuration
-w /etc/login.defs          -p wa -k login
-w /etc/securetty           -p wa -k login
-w /var/log/faillog         -p wa -k login
-w /var/log/lastlog         -p wa -k login

## Network config
-w /etc/hosts               -p wa -k network
# Directory changes under /etc/network
-w /etc/network             -p wa -k network

## Cron
-w /etc/crontab             -p wa -k cron
-w /etc/cron.d              -p wa -k cron

## SSH server config
-w /etc/ssh/sshd_config     -p wa -k sshd

## systemd configuration directory
-w /etc/systemd             -p wa -k systemd

## Sudoers
-w /etc/sudoers             -p wa -k sudoers
-w /etc/sudoers.d           -p wa -k sudoers

## Kernel module operations (prefer syscall-based over path watches)
-a always,exit -F arch=b64 -S init_module,finit_module,delete_module -k modules

# Default: keep rules reloadable on dev/base images.
# Production image policy can override this to -e 2 at rootfs postprocess time.
-e 1
