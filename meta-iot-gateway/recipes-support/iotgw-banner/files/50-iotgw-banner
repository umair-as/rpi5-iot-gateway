#!/bin/sh
# NetworkManager dispatcher: regenerate /etc/issue and /etc/issue.net
# on interface and connectivity-state events so the pre-login banner
# reflects the current IPs.
#
# Args from NM: $1 = interface name, $2 = action.
# connectivity-change: NM's connectivity state changed (online/offline).
#   Use this as the primary trigger for banner refresh on reachability events.
# up/down: interface state transitions that affect the routing table and
#   therefore the primary-IP display in the banner.
# dhcp4-change/dhcp6-change omitted: DHCP renewals do not change connectivity
#   state and fire frequently; they cause unnecessary banner rewrites with
#   identical content in stable networks.

case "$2" in
    up|down|connectivity-change)
        /usr/bin/iotgw-banner.sh issue issue.net >/dev/null 2>&1 || true
        ;;
esac
