# shellcheck shell=bash
# Host-local KAS/cache overrides. Copy to scripts/env.local.sh (gitignored)
# and set your real paths — nothing here is committed:
#
#   cp scripts/env.local.sh.example scripts/env.local.sh
#
# scripts/env.sh sources scripts/env.local.sh if it exists (directly, and via
# direnv/.envrc), so these values reach both `make` and standalone `kas`.

# Optional shared bare-repo layer cache (git alternates) for fast kas setup.
# Unset => kas does full clones (correct, just slower). Point at a per-release
# directory of bare mirrors, e.g. one dir per Yocto release.
export KAS_REPO_REF_DIR="/path/to/your/layer-cache"

# Optional: drive DL_DIR/SSTATE_DIR from the shell instead of kas/local.yml.
# (kas/local.yml is the usual place for these; uncomment only if you prefer env.)
# export DL_DIR="/path/to/shared/downloads"
# export SSTATE_DIR="/path/to/shared/sstate"
