# Auto-loaded by direnv when you `cd` into this repo.
# Exports KAS_WORK_DIR / KAS_BUILD_DIR / KAS_REPO_REF_DIR so raw
# `kas …` invocations behave the same as `make`. Without direnv,
# `. scripts/env.sh` per shell session does the same thing.
#
# First-time setup on this host:
#   sudo apt install direnv
#   echo 'eval "$(direnv hook bash)"' >> ~/.bashrc
#   exec bash
#   direnv allow             # confirm trust for this .envrc
#
# direnv reloads automatically when this file changes. To reload by
# hand: `direnv reload`. To pause for a shell: `direnv deny`.

source scripts/env.sh > /dev/null
