# Operator-private overlay. Copy to kas/local.yml (gitignored) and edit.
#
# Layers: this project uses the shared git-alternates mechanism (see the
# Makefile). Upstream layers are SHA-pinned in rpi5.yml / kas/*.yml and cloned
# into .kas/ (gitignored) using bare mirrors under KAS_REPO_REF_DIR (set in the
# gitignored scripts/env.local.sh; unset => full clones) as alternates —
# nothing to pre-clone, no path: overrides needed. For standalone `kas`
# (outside `make`), first run `. scripts/env.sh` to lift the KAS_* env into
# your shell.
header:
  version: 18
  includes:
    # Default to auto-fetch stack (RAUC-enabled by distro)
    - "kas/rpi5-autofetch.yml"

env:
  # Directory holding your RAUC signing keys. Prefer absolute path here.
  # Using $HOME is convenient, but expansion may depend on how kas is invoked.
  # If in doubt, replace with an absolute path (e.g., /home/you/rauc-keys).
  IOTGW_RAUC_KEY_DIR: "$HOME/rauc-keys"

local_conf_header:
  paths: |
    # Shared download + sstate caches on the NVMe drive so native/cross/allarch
    # sstate and all source downloads are reused. Point these at your shared drive.
    DL_DIR     = "/path/to/shared/downloads"
    SSTATE_DIR = "/path/to/shared/sstate"

  wifi: |
    # Inject Wi‑Fi profiles (static IPv4) — create 'kas/local.yml' from this file and edit.
    # Multiple lines separated by \n; format: ssid|psk|iface|method|priority|ipv4addr/prefix|gateway|dns1;dns2
    IOTGW_WIFI_NETWORKS = "HomeWiFi|Secret|wlan0|manual|100|192.168.0.222/24|192.168.0.1|1.1.1.1;8.8.8.8\nESP|Secret2|wlan0|manual|100|192.168.28.50/24|192.168.28.1|1.1.1.1;8.8.8.8"

  rauc_keys: |
    # Legacy flat-signed RAUC keys (single self-signed cert as both leaf signer
    # and device trust anchor). Keep this block during a migration window where
    # devices still carry the legacy single-cert keyring. Once devices boot the
    # directory-trust keyring configured via IOTGW_RAUC_KEYRING_CERTS below,
    # bundles can be re-signed with a chain-rooted leaf.
    # Store private keys outside the repo; adjust paths to your environment.
    # Prefer using IOTGW_RAUC_KEY_DIR defined in the 'env:' block above to avoid
    # relying on $HOME expansion in local_conf.
    RAUC_KEY_FILE = "${IOTGW_RAUC_KEY_DIR}/dev-key.pem"
    RAUC_CERT_FILE = "${IOTGW_RAUC_KEY_DIR}/dev-cert.pem"
  rauc_device_keyring: |
    # Single-cert keyring: trust anchor installed at /etc/rauc/ca.cert.pem.
    # Inert once IOTGW_RAUC_KEYRING_CERTS (below) is set — the recipe then
    # installs every listed cert into /etc/rauc/keyring.d/ instead, and RAUC's
    # [keyring] stanza switches from path= to directory=.
    RAUC_DEVICE_KEYRING = "${IOTGW_RAUC_KEY_DIR}/ca.cert.pem"
  rauc_pki_chain: |
    # === Chain-rooted RAUC PKI (Root → intermediate CA → annual signing leaf) ===
    # Layout under the operator's key tree:
    #   ${IOTGW_RAUC_KEY_DIR}/rauc-ca/root-ca/root-ca-<role>.crt        # exported Root cert(s)
    #   ${IOTGW_RAUC_KEY_DIR}/rauc-ca/dev-ca/dev-ca.cert.pem            # Dev intermediate
    #   ${IOTGW_RAUC_KEY_DIR}/rauc-ca/prod-ca/prod-ca.cert.pem          # Prod intermediate
    #   ${IOTGW_RAUC_KEY_DIR}/rauc-ca/issued/dev/iotgw-rauc-dev-signer-<YYYY>.{key,chain}.pem
    #
    # --- Transition image: dual-trust keyring (legacy + new Roots) ---
    # Bundles are still signed with the legacy key so devices on the single-cert
    # keyring can install this image; the new Roots are pre-positioned for the
    # following cutover.
    # IOTGW_RAUC_KEYRING_CERTS = " \
    #     ${IOTGW_RAUC_KEY_DIR}/dev-cert.pem \
    #     ${IOTGW_RAUC_KEY_DIR}/rauc-ca/root-ca/root-ca-primary.crt \
    #     ${IOTGW_RAUC_KEY_DIR}/rauc-ca/root-ca/root-ca-backup.crt"
    #
    # --- Cutover image: Root-only keyring; legacy signing retired ---
    # Bundles are signed with the new chain. The legacy cert is dropped from
    # the keyring directory; legacy-signed bundles will be rejected.
    # RAUC_KEY_FILE  = "${IOTGW_RAUC_KEY_DIR}/rauc-ca/issued/dev/iotgw-rauc-dev-signer-2026.key.pem"
    # RAUC_CERT_FILE = "${IOTGW_RAUC_KEY_DIR}/rauc-ca/issued/dev/iotgw-rauc-dev-signer-2026.chain.pem"
    # IOTGW_RAUC_KEYRING_CERTS = " \
    #     ${IOTGW_RAUC_KEY_DIR}/rauc-ca/root-ca/root-ca-primary.crt \
    #     ${IOTGW_RAUC_KEY_DIR}/rauc-ca/root-ca/root-ca-backup.crt"
    #
    # --- Optional prod CN allowlist (defence-in-depth on top of chain trust) ---
    # IOTGW_RAUC_ALLOWED_SIGNER_CNS = "iotgw-rauc-prod-signer-2026;iotgw-rauc-prod-signer-2027"
    #
    # --- Optional X.509 purpose enforcement on the signer chain ---
    # Leave empty during the transition (legacy signer cert typically has no
    # codeSigning EKU). Enable at the cutover image where every signing leaf
    # is chain-issued from a CA template that sets extendedKeyUsage = codeSigning.
    # IOTGW_RAUC_CHECK_PURPOSE = "codesign"
    #
    # --- Optional HSM-resident signing leaf (PKCS#11 URI form) ---
    # When the bundle-signing key lives in a hardware token instead of a file,
    # RAUC_KEY_FILE accepts a serial-anchored PKCS#11 URI. Examples:
    # RAUC_KEY_FILE = "pkcs11:token=<token-label>;id=<hex-id>;type=private"
    # RAUC_KEY_FILE = "pkcs11:token=atecc;object=rauc-signing-key;type=private"
  ota_ca_source: |
    # Optional: authoritative OTA mTLS CA source for ota-certs recipe.
    # Used to seed /etc/ota/ca.crt at build time and validate CA consistency.
    # Supported filenames in this directory:
    #   - ca.crt / ca.key
    #   - dev-ca.crt / dev-ca.key
    # Keep this aligned with simple-ota-server CA used to sign server/device certs.
    RAUC_OTA_CA_DIR = "${IOTGW_RAUC_KEY_DIR}/ota-dev-ca"

  fit_signing: |
    # === FIT signing (REQUIRED) — the build FAILS without a usable key ===
    # FIT signed boot is the ONLY supported flow (enforced by
    # iotgw-fit-signed-or-fail.bbclass; there is no unsigned build). Point these
    # at YOUR operator-generated, gitignored file key (never committed).
    # Generate one per docs/FIT_BOOT_SIGNING.md ("Generate a dev signing key").
    UBOOT_SIGN_KEYDIR  = "${IOTGW_RAUC_KEY_DIR}/fit"
    UBOOT_SIGN_KEYNAME = "iotgw-fit-dev"

  fit_dtb_yk_pubkey_trust: |
    # Optional: U-Boot control-FDT trust rotation for FIT signing keys.
    #
    # The kernel-fit recipe injects FIT public keys into the deployed
    # DTB so U-Boot's control FDT exposes /signature/key-<NAME> nodes
    # and enforces signed-FIT boot at runtime. Two trust roots can be
    # injected side-by-side during a key rotation:
    #
    #   - File-key (default ON): legacy build-time signing key, located
    #     at ${UBOOT_SIGN_KEYDIR}/${UBOOT_SIGN_KEYNAME}.{crt,key}. The
    #     FIT itself is signed with this key during bitbake.
    #   - YubiKey (off by default): public certificate exported from
    #     PIV slot 9a, located at ${IOTGW_FIT_YK_KEYDIR}/${IOTGW_FIT_YK_KEYNAME}.crt.
    #     No private key required on the build host. The FIT itself is
    #     post-build resigned via scripts/sign-fit.sh against the
    #     hardware-resident private key.
    #
    # Rotation window (both gates ON): DTB carries both pubkeys and
    # /signature/required-mode = "any" so a FIT signed by either root
    # verifies. Required while some bundles are file-signed and some
    # are HSM-signed.
    #
    # Production cutover (IOTGW_FIT_TRUST_FILE_KEY=0, only YK trusted):
    # the recipe injects only the YK pubkey and leaves required-mode
    # unset (single trust root — U-Boot's default verify semantics).
    # Use the kas/fit-release-trust.yml overlay (composed automatically
    # by make prod / bundle-prod-full / bundle-prod-full-fit) rather than
    # setting this gate in local.yml; that overlay also force-disables the
    # SoftHSM gate so a dev local.yml cannot leak it into a release.
    # Operator pre-flight: export slot 9a public cert with
    # `ykman piv certificates export 9a ${IOTGW_FIT_YK_KEYDIR}/${IOTGW_FIT_YK_KEYNAME}.crt`.
    #
    # Setting both gates to 0 is a build-time error.
    # IOTGW_FIT_TRUST_FILE_KEY = "1"
    # IOTGW_FIT_TRUST_YK_KEY = "1"
    # IOTGW_FIT_YK_KEYDIR = "${IOTGW_RAUC_KEY_DIR}/rauc-ca/fit"
    # IOTGW_FIT_YK_KEYNAME = "iotgw-fit-yk-2026"

  fit_dtb_softhsm_dev_trust: |
    # DEV-ONLY: optional SoftHSM-based FIT-signing trust root for engineers
    # without a YubiKey. SoftHSM stores keys in software, NOT a hardware
    # token — never enable this gate on a build intended for the field.
    # Operator provisions the dev key + cert via softhsm2-util + pkcs11-tool;
    # see docs/FIT_BOOT_SIGNING.md for the runbook.
    #
    # Two reasonable dev models:
    #
    #   1. Dual dev trust (recommended for shared hardware) — flip both
    #      YK and SoftHSM gates ON. DTB carries iotgw-fit-yk-2026 AND
    #      iotgw-fit-softhsm-dev with /signature/required-mode = "any".
    #      The same image boots either a real YK-signed FIT or a
    #      SoftHSM-signed FIT, so a YK-less developer and a YK-equipped
    #      developer can share the device for testing.
    #
    #   2. SoftHSM-only dev — leave YK gate OFF, flip SoftHSM gate ON.
    #      DTB trusts only iotgw-fit-softhsm-dev (single root, no
    #      required-mode written). Simpler but the device cannot boot
    #      production-style YK-signed artifacts.
    #
    # Any production build must keep IOTGW_FIT_TRUST_SOFTHSM_KEY off so
    # the device's runtime trust store contains only YubiKey-backed
    # roots.
    #
    # IOTGW_FIT_TRUST_SOFTHSM_KEY = "1"
    # IOTGW_FIT_SOFTHSM_KEYDIR = "${IOTGW_RAUC_KEY_DIR}/softhsm/fit"
    # IOTGW_FIT_SOFTHSM_KEYNAME = "iotgw-fit-softhsm-dev"

  buildhistory_downgrade_notes: |
    # Developer note: for intentional downgrade/maintenance tests (for example
    # switching kernel line 6.18 -> 6.12), package-history QA can trigger:
    #   version-going-backwards
    # Preferred temporary knob (demote to warning):
    # ERROR_QA:remove = "version-going-backwards"
    # WARN_QA:append = " version-going-backwards"
    #
    # Recipe-scoped alternative:
    # ERROR_QA:remove:pn-perf = "version-going-backwards"
    # WARN_QA:append:pn-perf = " version-going-backwards"
    #
    # Broader alternative (keeps image history but skips package history):
    # BUILDHISTORY_FEATURES:remove = "package"

  tpm_crypto_providers: |
    # Optional TPM crypto provider userspace integrations:
    # tpm2-pkcs11, tpm2-openssl, tpm2-tss-engine
    # Effective when TPM SPI profile is enabled on your build.
    # IOTGW_ENABLE_TPM_SLB9672 = "1"
    # IOTGW_ENABLE_TPM_CRYPTO_PROVIDERS = "1"

  ota_tpm_mtls: |
    # Optional OTA updater TPM-backed mTLS key flow (disabled by default).
    # When enabled:
    # - ota-updater uses TPM key handle URI instead of /etc/ota/device.key
    # - ota-certs allows keyless cert provisioning (device.crt + ca.crt)
    # IOTGW_ENABLE_OTA_TPM_MTLS = "1"
    # IOTGW_OTA_TPM_KEY_URI = "handle:0x81000001"
    # IOTGW_OTA_TPM_KEY_ENGINE = "tpm2tss"
    # IOTGW_OTA_OPENSSL_CONF = "/etc/ota/openssl-tpm2.cnf"

  rauc_pkcs11_streaming: |
    # Optional RAUC streaming PKCS#11 key flow (disabled by default).
    # IOTGW_RAUC_STREAMING_KEY_MODE = "pkcs11"
    # IOTGW_RAUC_PKCS11_BACKEND = "tpm2"
    # TPM2 preset (defaults in layer):
    # IOTGW_RAUC_PKCS11_TLS_KEY_TPM2 = "pkcs11:token=iotgw;object=rauc-client-key;type=private;pin-source=file:/etc/ota/pkcs11-pin"
    # TPM2 PKCS#11 DB location for RAUC sandbox-helper:
    # IOTGW_TPM2_PKCS11_STORE = "/var/lib/tpm2_pkcs11"
    # Custom backend example:
    # IOTGW_RAUC_PKCS11_TLS_KEY_CUSTOM = "pkcs11:token=<token>;object=<key>;type=private"
    # IOTGW_RAUC_PKCS11_MODULE_CUSTOM = "/usr/lib/pkcs11/<provider>.so"
    # IOTGW_RAUC_PKCS11_PROVIDER_PACKAGES_CUSTOM = "<provider-package>"

  rauc_bundle_encryption: |
    # Optional encrypted RAUC bundle flow.
    # IOTGW_ENABLE_RAUC_BUNDLE_ENCRYPTION = "1"
    # IOTGW_RAUC_BUNDLE_ENCRYPT_RECIPIENTS = "/home/you/rauc-keys/ota-dev-ca/device-filekey.crt"
    # IOTGW_RAUC_ENCRYPTION_KEY = "/etc/ota/device.key"
    # IOTGW_RAUC_ENCRYPTION_CERT = "/etc/ota/device.crt"

  ota_feature_profiles: |
    # Profile A: baseline verity + file-key (no TPM required)
    # IOTGW_ENABLE_OTA_TPM_MTLS = "0"
    # IOTGW_RAUC_STREAMING_KEY_MODE = "file"
    # IOTGW_ENABLE_RAUC_BUNDLE_ENCRYPTION = "0"
    # Profile B: full TPM + PKCS#11 + encrypted-bundle lane
    # IOTGW_ENABLE_TPM_SLB9672 = "1"
    # IOTGW_ENABLE_OTA_TPM_MTLS = "1"
    # IOTGW_OTA_TPM_KEY_URI = "handle:0x81000001"
    # IOTGW_OTA_TPM_KEY_ENGINE = "tpm2tss"
    # IOTGW_OTA_OPENSSL_CONF = "/etc/ota/openssl-tpm2.cnf"
    # IOTGW_RAUC_STREAMING_KEY_MODE = "pkcs11"
    # IOTGW_RAUC_PKCS11_BACKEND = "tpm2"
    # IOTGW_ENABLE_RAUC_BUNDLE_ENCRYPTION = "1"
    # IOTGW_RAUC_BUNDLE_ENCRYPT_RECIPIENTS = "/home/you/rauc-keys/ota-dev-ca/device-filekey.crt"
    # IOTGW_RAUC_ENCRYPTION_KEY = "/etc/ota/device.key"
    # IOTGW_RAUC_ENCRYPTION_CERT = "/etc/ota/device.crt"

  btf_core_dev_toggle: |
    # Optional kernel BTF/CO-RE lab metadata gate.
    # Keep disabled by default; enable for eBPF/libbpf CO-RE workflows.
    # IOTGW_ENABLE_BTF_CORE_DEV = "1"
